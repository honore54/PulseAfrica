# ============================================================
#  PulseAfrica — Environment Variables (example/sanitized)
#  Copy this to .env.local and fill in your keys
# ============================================================

# Anthropic (required) — https://console.anthropic.com
ANTHROPIC_API_KEY=REPLACE_WITH_ANTHROPIC_API_KEY

# Supabase (required) — https://supabase.com (free)
NEXT_PUBLIC_SUPABASE_URL=REPLACE_WITH_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SUPABASE_SERVICE_ROLE_KEY

# NewsAPI (free tier = 100 requests/day) — https://newsapi.org
NEWS_API_KEY=REPLACE_WITH_NEWSAPI_KEY

# Cron job secret (make up any random string)
CRON_SECRET=REPLACE_WITH_CRON_SECRET

# Site URL
NEXT_PUBLIC_SITE_URL=https://pulseafrica.vercel.app
